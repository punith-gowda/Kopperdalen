# Firebase web config for the Kopperdalen app.
# Copy this file to `.env.local` (git-ignored) and fill in the values from
# the Firebase console: Project settings → General → Your apps → SDK config.
# These are not secrets; real access is controlled by Firestore security rules.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
